# Local development (no Docker)
APP_ENV=development
SECRET_KEY=dev-local-secret-change-in-production
API_URL=http://localhost:8000

# SQLite database — stored in ./data/lux_arbitrage.db
# For production use PostgreSQL, e.g. Neon or Supabase:
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db

# CORS — add your Vercel URL after deploy
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Meilisearch off for local (optional)
MEILISEARCH_ENABLED=false

# Live scrapers
VINTED_ENABLED=true
OSKELLY_ENABLED=true
SCRAPER_LISTINGS_PER_QUERY=15
VINTED_MAX_PAGES=2
OSKELLY_MAX_PAGES=2

# Frontend (also set in frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
